{
  "$schema": "https://json.schemastore.org/eas.json",
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://katypic-api-production.up.railway.app"
      }
    },
    "beta": {
      "distribution": "store",
      "autoIncrement": true,
      "channel": "preview",
      "ios": { "resourceClass": "m-medium" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://katypic-api-production.up.railway.app",
        "EXPO_PUBLIC_DISABLE_APPLE_AUTH": "true",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "ios": { "resourceClass": "m-medium" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleTeamId": "M9552LZ63U",
        "ascAppId": "6760631395",
        "ascApiKeyPath": "./AuthKey_79LM9M49D7.p8",
        "ascApiKeyIssuerId": "01b2d9bc-e678-4f25-95a2-9bfeb304b686",
        "ascApiKeyId": "79LM9M49D7"
      },
      "android": {
        "serviceAccountKeyPath": "./google-services.json",
        "track": "production"
      }
    }
  }
}
